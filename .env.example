PORT="8080"

# Supabase
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"
JWT_SECRET="<jwt-secret>"

# Base de datos (Supabase pooler)
DB_USER="postgres.<project-ref>"
DB_PASSWORD="<db-password>"
DB_HOST="aws-1-us-east-1.pooler.supabase.com"
DB_PORT="5432"
DB_NAME="postgres"

# Brevo (email transaccional)
BREVO_API_KEY="<brevo-api-key>"
BREVO_FROM_EMAIL="you@example.com"

# Google Cloud Vision (ruta al service account JSON, no commitear el JSON)
GOOGLE_APPLICATION_CREDENTIALS="./portfolio-logins-xxxxxxxxxxxx.json"
